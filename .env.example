# Bu dosyayi .env olarak kopyalayip gercek degerleri girin. .env asla git'e girmez.

# --- LLM Provider (Faz 4 - RAG) ---
# "anthropic", "openai" veya "huggingface" (varsayilan, ucretsiz - token icin
# https://huggingface.co/settings/tokens, kart gerektirmez)
LLM_PROVIDER=huggingface
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=

# --- API (Faz 6) ---
API_HOST=0.0.0.0
API_PORT=8000
