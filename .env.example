# Bu dosyayi .env olarak kopyalayip gercek degerleri girin. .env asla git'e girmez.

# --- LLM Provider (Faz 4 - RAG) ---
# "anthropic", "openai" veya "huggingface" (varsayilan, ucretsiz - token icin
# https://huggingface.co/settings/tokens, kart gerektirmez)
LLM_PROVIDER=huggingface
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=

# --- API (Faz 6) ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Kimlik Dogrulama (JWT - kullanici girisi/kaydi) ---
# ONEMLI: Bos birakilirsa kod icinde sabit bir varsayilan anahtara duser - bu varsayilan
# public repoda gorunur oldugundan GUVENLI DEGILDIR. Gercek/deploy ortaminda MUTLAKA
# kendi rastgele degerinizi girin, ornegin: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
